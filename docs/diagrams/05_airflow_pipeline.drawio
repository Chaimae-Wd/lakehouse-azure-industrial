        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart LR\n\nSTART((START))\n\nBRONZE[\&quot;BRONZE INGESTION&lt;br/&gt;&lt;br/&gt;Extract PostgreSQL data&lt;br/&gt;Load raw datasets&lt;br/&gt;Add ingestion metadata\&quot;]\n\nSILVER[\&quot;SILVER TRANSFORMATION&lt;br/&gt;&lt;br/&gt;Clean data&lt;br/&gt;Validate schemas&lt;br/&gt;Remove duplicates&lt;br/&gt;Apply business rules\&quot;]\n\nGOLD[\&quot;GOLD AGGREGATION&lt;br/&gt;&lt;br/&gt;Build fact tables&lt;br/&gt;Build dimensions&lt;br/&gt;Calculate KPIs&lt;br/&gt;Prepare analytics data\&quot;]\n\nDQ{\&quot;DATA QUALITY&lt;br/&gt;&lt;br/&gt;Completeness checks&lt;br/&gt;Null-value checks&lt;br/&gt;Row-count validation&lt;br/&gt;Business-rule validation\&quot;}\n\nSUCCESS[\&quot;PIPELINE SUCCESS&lt;br/&gt;&lt;br/&gt;Publish datasets&lt;br/&gt;Update execution status&lt;br/&gt;Data ready for Power BI\&quot;]\n\nEND((END))\n\nSTART --&gt;|\&quot;Trigger DAG\&quot;| BRONZE\nBRONZE --&gt;|\&quot;Bronze completed\&quot;| SILVER\nSILVER --&gt;|\&quot;Silver completed\&quot;| GOLD\nGOLD --&gt;|\&quot;Gold completed\&quot;| DQ\nDQ --&gt;|\&quot;Validation passed\&quot;| SUCCESS\nSUCCESS --&gt;|\&quot;Close workflow\&quot;| END\n\nclassDef startEnd fill:#E8F5E9,stroke:#388E3C,stroke-width:3px,color:#1F2937;\nclassDef bronze fill:#A94F0A,stroke:#743405,stroke-width:2px,color:#FFFFFF;\nclassDef silver fill:#E6E6E6,stroke:#808080,stroke-width:2px,color:#1F2937;\nclassDef gold fill:#FFD966,stroke:#C9A000,stroke-width:2px,color:#1F2937;\nclassDef quality fill:#E3F2FD,stroke:#1976D2,stroke-width:2px,color:#1F2937;\nclassDef success fill:#DFF2E1,stroke:#4F8A57,stroke-width:2px,color:#1F2937;\n\nclass START,END startEnd;\nclass BRONZE bronze;\nclass SILVER silver;\nclass GOLD gold;\nclass DQ quality;\nclass SUCCESS success;\n\nlinkStyle default stroke:#4B5563,stroke-width:2px;&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="HrqNwB40erLUelhpke29-1">
